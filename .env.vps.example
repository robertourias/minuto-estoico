# Copie para .env e preencha os valores

# PostgreSQL (senha forte, não use "postgres" em produção)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=minuto_estoico

# URLs públicas — substitua pelo seu domínio
FRONTEND_URL=https://SEU_DOMINIO.com
NEXT_PUBLIC_API_URL=https://api.SEU_DOMINIO.com/api
