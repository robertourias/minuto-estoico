# ──────────────────────────────────────────────
# SUPABASE — obtenha em: Project Settings → Database
# ──────────────────────────────────────────────

# Pooler (Transaction Mode, porta 6543) — usado pela aplicação em produção
DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexão direta (porta 5432) — usado pelo Prisma para migrations
DIRECT_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ──────────────────────────────────────────────
# LOCAL (desenvolvimento)
# ──────────────────────────────────────────────
# DATABASE_URL="postgresql://postgres:postgres@localhost:5452/minuto_estoico?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5452/minuto_estoico"

# App
PORT=3021
NODE_ENV=development

# CORS - URL do frontend
FRONTEND_URL=http://localhost:3020
