generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // URL do pooler (porta 6543) — usada pela aplicação
  directUrl = env("DIRECT_URL")         // URL direta (porta 5432) — usada pelo Prisma para migrations
}

model Quote {
  id         String   @id @default(uuid())
  text       String
  author     String
  reflection String
  category   String
  tags       String[]
  language   String   @default("pt")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("quotes")
  @@index([category])
  @@index([language])
}
