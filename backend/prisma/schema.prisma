generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quote {
  id         String   @id @default(uuid())
  text       String
  author     String
  reflection String
  category   String
  tags       String[]
  language   String   @default("pt")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("quotes")
  @@index([category])
  @@index([language])
}
